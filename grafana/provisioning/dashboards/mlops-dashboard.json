{
  "title": "Sports Retail MLOps Dashboard",
  "panels": [
    {
      "title": "Total Revenue (last 24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "bfq1j1d5i37r4a"
          },
          "rawSql": "SELECT SUM(total_amount) AS revenue FROM orders WHERE timestamp > (now() - INTERVAL 1 DAY)",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 }
    },
    {
      "title": "A/B Test: Average Check by Group",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "bfq1j1d5i37r4a"
          },
          "rawSql": "SELECT experiment_group, AVG(total_amount) AS avg_check FROM orders GROUP BY experiment_group ORDER BY avg_check DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 8 }
    },
    {
      "title": "Revenue by Channel",
      "type": "piechart",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "bfq1j1d5i37r4a"
          },
          "rawSql": "SELECT channel, SUM(total_amount) AS revenue FROM orders GROUP BY channel ORDER BY revenue DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 }
    },
    {
      "title": "Top Product Categories",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "bfq1j1d5i37r4a"
          },
          "rawSql": "SELECT product_category, COUNT(*) AS orders_count FROM orders GROUP BY product_category ORDER BY orders_count DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 8 }
    },
    {
      "title": "Promo vs No Promo",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "bfq1j1d5i37r4a"
          },
          "rawSql": "SELECT promo, COUNT(*) AS count FROM orders GROUP BY promo ORDER BY count DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 4 }
    },
    {
      "title": "Weekend vs Weekday Revenue",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "bfq1j1d5i37r4a"
          },
          "rawSql": "SELECT is_weekend, SUM(total_amount) AS revenue FROM orders GROUP BY is_weekend",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 4 }
    }
  ],
  "schemaVersion": 27
}